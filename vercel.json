{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api/scout/(.*)",
      "destination": "/api/scout/$1"
    },
    {
      "source": "/api/whatsapp/(.*)",
      "destination": "/api/whatsapp/$1"
    },
    {
      "source": "/provider.html",
      "destination": "/provider.html"
    },
    {
      "source": "/client.html",
      "destination": "/client.html"
    },
    {
      "source": "/scout.html",
      "destination": "/scout.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}