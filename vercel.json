{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://byajcqrgetloavrgyqak.supabase.co https://api.anthropic.com https://api.github.com https://cdnjs.cloudflare.com"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api/scout/(.*)",
      "destination": "/api/scout/$1"
    },
    {
      "source": "/api/whatsapp/(.*)",
      "destination": "/api/whatsapp/$1"
    },
    {
      "source": "/provider.html",
      "destination": "/provider.html"
    },
    {
      "source": "/client.html",
      "destination": "/client.html"
    },
    {
      "source": "/scout.html",
      "destination": "/scout.html"
    },
    {
      "source": "/api/cascade",
      "destination": "/api/cascade"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}